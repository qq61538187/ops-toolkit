# 容器名称（多实例部署时区分不同 docmost 容器）
DOCMOST_APP_CONTAINER_NAME=docmost-app
DOCMOST_DB_CONTAINER_NAME=docmost-db
DOCMOST_REDIS_CONTAINER_NAME=docmost-redis

# 应用
DOCMOST_APP_URL=http://localhost:13001
DOCMOST_APP_SECRET=fdcb8b2afa0ee9aaa8df06fa178a23b976468b1c29a92fa13db1c23c70e89451
DOCMOST_PORT=13001

# 数据库（Postgres）
DOCMOST_DB_NAME=docmost
DOCMOST_DB_USER=docmost
DOCMOST_DB_PASSWORD=d116bb34d289067618bf73b3

# 连接串（主机名即 compose 服务名，容器间同网互通）
DOCMOST_DATABASE_URL=postgresql://docmost:d116bb34d289067618bf73b3@docmost-db:5432/docmost?schema=public
DOCMOST_REDIS_URL=redis://docmost-redis:6379

# 共享网络名称（多个应用/nginx 容器互访时使用同一个名称即可互通）
DOCMOST_NETWORK_NAME=devbox-shared-net
